     "text": [
      "Enter add,list or quit: add\n"
     ]
    }
   ],
   "source": [
    "habits = []\n",
    "while True:\n",
    "    command = input(\"Enter add,list or quit:\")\n",
    "\n",
    "    if command == \"add\":\n",
    "        habit = input(\"Enter habit:\")\n",
    "        habits.append(habit)\n",
    "\n",
    "    elif command == \"list\":\n",
    "        print(habits)\n",
    "    elif command == \"quit\":\n",
    "        break"
   ]
  },
